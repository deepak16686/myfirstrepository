# ============================================================
# MCP Server Environment Variables
# Copy this file to .env.mcp and fill in your values
# ============================================================

# --- Terraform (HashiCorp Cloud / Terraform Enterprise) ---
# Optional: only needed for HCP Terraform / TFE workspace operations
TFE_ADDRESS=https://app.terraform.io
TFE_TOKEN=

# --- Ansible ---
# pip install mcp-ansible (required before use)
ANSIBLE_PROJECT_ROOT=/path/to/ansible/project
ANSIBLE_INVENTORY=/path/to/inventory.yml
ANSIBLE_PROJECT_NAME=my-project

# --- Kubernetes ---
# Defaults to ~/.kube/config if not set
KUBECONFIG=~/.kube/config

# --- Docker ---
# Auto-detects Docker socket, no config needed
# DOCKER_HOST=tcp://localhost:2376  # Uncomment for remote Docker

# --- Ollama ---
# Local Ollama server (default port 11434)
OLLAMA_HOST=http://localhost:11434
# OLLAMA_API_KEY=                   # Uncomment for Ollama Cloud

# --- Telegram ---
# Get bot token from @BotFather on Telegram
# Get chat ID by running: npx mcptelegram-chatid
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Prometheus ---
PROMETHEUS_URL=http://localhost:9090
# PROMETHEUS_USERNAME=              # Uncomment for basic auth
# PROMETHEUS_PASSWORD=              # Uncomment for basic auth

# --- Grafana ---
# Create a service account token in Grafana: Administration > Service accounts
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# --- Jenkins ---
# Generate API token in Jenkins: User > Configure > API Token
JENKINS_URL=http://localhost:8080
JENKINS_USER=
JENKINS_API_TOKEN=

# --- Harness ---
# Get from Harness: Account Settings > API Keys
HARNESS_API_KEY=
HARNESS_ACCOUNT_ID=
HARNESS_ORG_ID=
HARNESS_PROJECT_ID=

# --- Selenium ---
# No env vars needed - ensure browser + WebDriver are installed
# ChromeDriver: https://chromedriver.chromium.org/downloads

# --- SonarQube ---
# Generate token in SonarQube: My Account > Security > Generate Token (User token)
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=
SONARQUBE_ORG=                      # Required only for SonarQube Cloud
