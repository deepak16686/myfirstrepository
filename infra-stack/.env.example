# =============================================================================
# INFRASTRUCTURE STACK — Environment Variables
# Copy to .env and fill in values before starting the stack.
# =============================================================================

# ── GitLab ────────────────────────────────────────────────────────────────────
# Personal Access Token for GitLab root user (seeded into Vault on first run)
# Get from: http://localhost:8929/gitlab/-/user_settings/personal_access_tokens
GITLAB_PAT=

# ── Gitea ─────────────────────────────────────────────────────────────────────
# Runner registration token (get from Gitea Admin > Actions > Runners)
GITEA_RUNNER_TOKEN=mHgHYvs7ei1F47cVrEwijEdReGXEYXUrGUQDzRLx

# ── Jenkins ───────────────────────────────────────────────────────────────────
# Agent secrets (from Jenkins > Manage Nodes > agent-X > Secret)
JENKINS_AGENT_SECRET_1=66fbf53f95bb677bd41780239be7474afd24d1e34a11814e0f32e97489d89880
JENKINS_AGENT_SECRET_2=fe466dc2c3c658e66071cbb8df177ef227120fb4b448ccb7c1a9ed753b3924ab
JENKINS_AGENT_SECRET_3=c819856611f0faf66a354351faad64b1406bb3e470b1906b6e0ea6fa5c61dd5e
